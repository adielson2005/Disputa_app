# ─────────────────────────────────────────────────────────────────────────────
# GolApp — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores ANTES de rodar o projeto.
# NUNCA commite o arquivo .env no Git.
# ─────────────────────────────────────────────────────────────────────────────

FLASK_ENV=development          # development | production | testing

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere valores seguros com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE_POR_VALOR_ALEATORIO_SEGURO
SECRET_KEY=TROQUE_POR_OUTRO_VALOR_ALEATORIO_SEGURO

# ── Banco de dados ────────────────────────────────────────────────────────────
# Desenvolvimento: deixe em branco para usar SQLite local (golapp.db)
# DATABASE_URL=sqlite:///golapp.db

# Produção (PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Horas de expiração do token JWT (padrão: 8)
JWT_EXPIRATION_HOURS=8
